# Environment variables for Next.js app

# Database (Prisma)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# URL pública del web app (sin slash final). Se usa para armar links en
# emails (informes suscriptos, etc). En producción detrás de nginx el
# contenedor escucha en localhost:8080 y request.origin no sirve.
NEXT_PUBLIC_API_URL="https://axp.com.ar"

# Supabase (optional if using Supabase client)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Cloudflare R2 (para visualización de PDFs)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"

# AI Review (Anthropic Claude)
ANTHROPIC_API_KEY="sk-ant-..."

# Resend (email inbound + outbound)
# Crear en https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Configurar en Resend Dashboard > Webhooks (usar el secreto con prefijo whsec_)
RESEND_WEBHOOK_SECRET="whsec_..."
# Bucket R2 donde guardar PDFs de senders no resueltos (opcional, default: axp-unresolved)
R2_UNRESOLVED_BUCKET="axp-unresolved"

# Next.js
NODE_ENV="development"
