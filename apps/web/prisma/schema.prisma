generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model clientes {
  id              String            @id @db.Uuid
  razonSocial     String            @db.VarChar(255)
  cuit            String            @unique @db.VarChar(11)
  r2Prefix        String            @db.VarChar(50)
  activo          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime          @db.Timestamptz(3)
  documentos      documentos[]
  ingest_queue    ingest_queue[]
  pagos           pagos[]
  proveedores     proveedores[]
  usuarios        usuarios[]
  processing_logs  processing_logs[]
  email_templates  email_templates[]
  ai_usage_logs    ai_usage_logs[]
  sales_closures        sales_closures[]
  sales_product_master  sales_product_master[]
  sales_report_subscriptions sales_report_subscriptions[]
  insumos          insumos[]
  ventas           ventas[]
}

model ventas {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId     String        @db.Uuid
  fecha         DateTime      @db.Date
  nroDocumento  String?       @db.VarChar(100)
  tipoDoc       String?       @db.VarChar(50)
  clienteNombre String?       @db.VarChar(255)
  formaPago     String?       @db.VarChar(100)
  subtotal      Decimal?      @db.Decimal(14, 2)
  total         Decimal?      @db.Decimal(14, 2)
  createdAt     DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(3)
  clientes      clientes      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  venta_items   venta_items[]

  @@index([clienteId, fecha])
  @@index([clienteId, nroDocumento])
}

model venta_items {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ventaId        String   @db.Uuid
  linea          Int
  descripcion    String   @db.Text
  cantidad       Decimal? @db.Decimal(14, 3)
  precioUnitario Decimal? @db.Decimal(14, 2)
  subtotal       Decimal? @db.Decimal(14, 2)
  ventas         ventas   @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([ventaId])
}

model documento_items {
  id             String     @id @db.Uuid
  documentoId    String     @db.Uuid
  linea          Int
  descripcion    String @db.Uuid
  codigo         String?    @db.VarChar(100)
  cantidad       Decimal?   @db.Decimal(14, 3)
  unidad         String?    @db.VarChar(20)
  precioUnitario Decimal?   @db.Decimal(14, 2)
  subtotal       Decimal?   @db.Decimal(14, 2)
  documentos     documentos @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([documentoId])
}

model documento_revisiones {
  id          String         @id @db.Uuid
  documentoId String         @db.Uuid
  usuarioId   String         @db.Uuid
  accion      AccionRevision
  path        String         @db.VarChar(255)
  before      Json?
  after       Json?
  createdAt   DateTime       @default(now()) @db.Timestamptz(3)
  documentos  documentos     @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  usuarios    usuarios       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([documentoId, createdAt(sort: Desc)])
}

model documento_anotaciones {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoId String     @db.Uuid
  usuarioId   String     @db.Uuid
  texto       String     @db.Text
  createdAt   DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime   @default(now()) @db.Timestamptz(3)
  documentos  documentos @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  usuarios    usuarios   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([documentoId])
}

model documentos {
  id                   String                 @id @db.Uuid
  clienteId            String                 @db.Uuid
  proveedorId          String?                @db.Uuid
  tipo                 TipoDocumento
  letra                LetraFactura?
  puntoVenta           String?                @db.VarChar(10)
  numero               String?                @db.VarChar(20)
  numeroCompleto       String?                @db.VarChar(50)
  fechaEmision         DateTime?              @db.Date
  fechaVencimiento     DateTime?              @db.Date
  moneda               String                 @default("ARS") @db.VarChar(3)
  subtotal             Decimal?               @db.Decimal(14, 2)
  iva                  Decimal?               @db.Decimal(14, 2)
  total                Decimal?               @db.Decimal(14, 2)
  confidenceScore      Int?
  estadoRevision       EstadoRevision         @default(PENDIENTE)
  missingFields        Json                   @default("[]")
  jsonNormalizado      Json                   @default("{}")
  source               SourceDocumento
  hashSha256           String                 @db.VarChar(64)
  pdfRawKey            String                 @db.VarChar(500)
  pdfFinalKey          String?                @db.VarChar(500)
  textractRawKey       String?                @db.VarChar(500)
  createdAt            DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime               @db.Timestamptz(3)
  documento_items       documento_items[]
  documento_revisiones  documento_revisiones[]
  documento_anotaciones documento_anotaciones[]
  clientes              clientes               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  proveedores           proveedores?           @relation(fields: [proveedorId], references: [id])
  pago_documentos       pago_documentos[]
  processing_logs       processing_logs[]
  ai_usage_logs         ai_usage_logs[]

  @@unique([clienteId, hashSha256])
  @@index([clienteId, estadoRevision])
  @@index([clienteId, fechaEmision])
  @@index([clienteId, numeroCompleto])
  @@index([clienteId, proveedorId])
  @@index([hashSha256])
}

model ingest_queue {
  id          String            @id @db.Uuid
  clienteId   String            @db.Uuid
  source      SourceIngestQueue
  sourceRef   String            @db.VarChar(500)
  sha256      String?           @db.VarChar(64)
  status      StatusIngestQueue @default(PENDING)
  attempts    Int               @default(0)
  nextRetryAt DateTime?         @db.Timestamptz(3)
  lastError   String?
  createdAt   DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime          @db.Timestamptz(3)
  clientes    clientes          @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, source, sourceRef])
  @@index([clienteId, status])
  @@index([status, nextRetryAt])
}

model pago_documentos {
  pagoId        String     @db.Uuid
  documentoId   String     @db.Uuid
  montoAplicado Decimal    @db.Decimal(14, 2)
  createdAt     DateTime   @default(now()) @db.Timestamptz(3)
  documentos    documentos @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  pagos         pagos      @relation(fields: [pagoId], references: [id], onDelete: Cascade)

  @@id([pagoId, documentoId])
}

model pago_metodos {
  id     String         @id @db.Uuid
  pagoId String         @db.Uuid
  tipo   TipoPagoMetodo
  monto  Decimal        @db.Decimal(14, 2)
  meta   Json           @default("{}")
  pagos  pagos          @relation(fields: [pagoId], references: [id], onDelete: Cascade)

  @@index([pagoId])
}

model pagos {
  id              String            @id @db.Uuid
  clienteId       String            @db.Uuid
  proveedorId     String            @db.Uuid
  numero          Int
  fecha           DateTime          @db.Date
  estado          EstadoPago        @default(BORRADOR)
  moneda          String            @default("ARS") @db.VarChar(3)
  montoTotal      Decimal           @db.Decimal(14, 2)
  nota            String?
  comprobanteKey  String?           @db.VarChar(500)
  createdAt       DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime          @db.Timestamptz(3)
  pago_documentos pago_documentos[]
  pago_metodos    pago_metodos[]
  clientes        clientes          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  proveedores     proveedores       @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@unique([clienteId, numero])
  @@index([clienteId, fecha])
  @@index([clienteId, proveedorId])
}

model proveedores {
  id          String        @id @db.Uuid
  clienteId   String        @db.Uuid
  razonSocial String        @db.VarChar(255)
  cuit        String?       @db.VarChar(11)
  alias       Json          @default("[]")
  letra       String?       @db.VarChar(1)
  email       String?       @db.VarChar(255)
  telefono    String?       @db.VarChar(20)
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime      @db.Timestamptz(3)
  documentos  documentos[]
  pagos       pagos[]
  clientes    clientes      @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, cuit])
  @@index([clienteId])
  @@index([clienteId, razonSocial])
  @@index([email])
}

model usuarios {
  id                   String                 @id @db.Uuid
  email                String                 @unique @db.VarChar(255)
  nombre               String                 @db.VarChar(255)
  rol                  RolUsuario
  tipo_acceso          String?                @default("VIEWER") @db.VarChar(255)
  clienteId            String?                @db.Uuid
  activo               Boolean                @default(true)
  createdAt            DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime               @db.Timestamptz(3)
  documento_revisiones  documento_revisiones[]
  documento_anotaciones documento_anotaciones[]
  ai_usage_logs         ai_usage_logs[]
  clientes              clientes?              @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([rol])
}

model processing_logs {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id   String    @db.Uuid
  level        String    @db.Text
  source       String    @db.Text
  message      String    @db.Text
  details      Json      @default("{}")
  documento_id String?   @db.Uuid
  filename     String?   @db.Text
  read         Boolean   @default(false)
  created_at   DateTime  @default(now()) @db.Timestamptz(3)

  clientes   clientes    @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  documentos documentos? @relation(fields: [documento_id], references: [id], onDelete: SetNull)

  @@index([cliente_id])
  @@index([level])
  @@index([created_at(sort: Desc)])
  @@index([cliente_id, read])
}

enum AccionRevision {
  SET_FIELD
  SET_PROVIDER
  EDIT_ITEM
  CONFIRM
}

enum EstadoPago {
  BORRADOR
  EMITIDA
  PAGADO
  ANULADO
}

enum EstadoRevision {
  PENDIENTE
  CONFIRMADO
  ERROR
  DUPLICADO
  PAGADO
}

enum LetraFactura {
  A
  B
  C
}

enum RolUsuario {
  SUPERADMIN
  ADMIN
  USER
}

enum SourceDocumento {
  SFTP
  EMAIL
  WHATSAPP
  MANUAL
}

enum SourceIngestQueue {
  SFTP
  DRIVE
  EMAIL
}

enum StatusIngestQueue {
  PENDING
  PROCESSING
  DONE
  ERROR
}

enum TipoDocumento {
  FACTURA
  REMITO
  NOTA_CREDITO
}

enum TipoPagoMetodo {
  EFECTIVO
  TRANSFERENCIA
  CHEQUE
  ECHEQ
}

model email_templates {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId String            @db.Uuid
  tipo      TipoEmailTemplate
  asunto    String            @db.VarChar(500)
  cuerpo    String            @db.Text
  activo    Boolean           @default(true)
  createdAt DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt DateTime          @db.Timestamptz(3)
  clientes  clientes          @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, tipo])
  @@index([clienteId])
}

enum TipoEmailTemplate {
  ORDEN_PAGO
  COMPARTIR_DOCUMENTOS
}

model ai_usage_logs {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoId      String      @db.Uuid
  clienteId        String      @db.Uuid
  usuarioId        String?     @db.Uuid
  modelo           String      @db.VarChar(100)
  inputTokens      Int
  outputTokens     Int
  costoEstimado    Decimal     @db.Decimal(10, 6)
  camposCorregidos Json        @default("[]")
  camposSugeridos  Json        @default("{}")
  aceptado         Boolean     @default(false)
  durationMs       Int?
  errorMessage     String?     @db.Text
  source           String      @default("MANUAL") @db.VarChar(20)
  createdAt        DateTime    @default(now()) @db.Timestamptz(3)

  documentos documentos  @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  clientes   clientes    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuarios   usuarios?   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([clienteId, createdAt(sort: Desc)])
  @@index([documentoId])
}

// =====================================================
// MODULO: VENTAS / CIERRES DE CAJA MAXIREST
// =====================================================

enum TurnoNombre {
  ALMUERZO
  CENA
  OTRO
}

enum MovimientoTipo {
  INGRESO
  EGRESO
}

model sales_closures {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId           String      @db.Uuid
  fecha               DateTime    @db.Date
  nroCierre           Int
  turnoNombre         TurnoNombre @default(OTRO)
  turnoNumero         Int?
  sucursal            String?     @db.VarChar(100)
  empresaNombre       String?     @db.VarChar(255)
  cuit                String?     @db.VarChar(11)
  domicilio           String?     @db.VarChar(255)
  usuarioApertura     String?     @db.VarChar(50)
  horaApertura        String?     @db.VarChar(8)
  usuarioCierre       String?     @db.VarChar(50)
  horaCierre          String?     @db.VarChar(8)
  totalIngresos       Decimal?    @db.Decimal(14, 2)
  totalEgresos        Decimal?    @db.Decimal(14, 2)
  saldoCaja           Decimal?    @db.Decimal(14, 2)
  totalVentas         Decimal?    @db.Decimal(14, 2)
  cantTickets         Int?
  efectivo            Decimal?    @db.Decimal(14, 2)
  ctaCte              Decimal?    @db.Decimal(14, 2)
  tarjetas            Decimal?    @db.Decimal(14, 2)
  facturaAElectronica     Decimal? @db.Decimal(14, 2)
  cantFacturaAElectronica Int?
  facturaBElectronica     Decimal? @db.Decimal(14, 2)
  cantFacturaBElectronica Int?
  facturaB                Decimal? @db.Decimal(14, 2)
  cantFacturaB            Int?
  notaCreditoAElectronica     Decimal? @db.Decimal(14, 2)
  cantNotaCreditoAElectronica Int?
  notaCreditoBElectronica     Decimal? @db.Decimal(14, 2)
  cantNotaCreditoBElectronica Int?
  notaCreditoB                Decimal? @db.Decimal(14, 2)
  cantNotaCreditoB            Int?
  descuentoTotal      Decimal?    @db.Decimal(14, 2)
  cantCubiertos       Decimal?    @db.Decimal(10, 2)
  promedioCubierto    Decimal?    @db.Decimal(14, 2)
  netoGravado         Decimal?    @db.Decimal(14, 2)
  ivaTotal            Decimal?    @db.Decimal(14, 2)
  pdfR2Key            String?     @db.VarChar(500)
  rawText             String?     @db.Text
  source              String      @default("EMAIL") @db.VarChar(20)
  createdAt           DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime    @updatedAt @db.Timestamptz(3)

  clientes            clientes                  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  payments            sales_closure_payments[]
  items               sales_closure_items[]
  waiters             sales_closure_waiters[]
  movements           sales_closure_movements[]
  auditEvents         sales_closure_audit_events[]

  @@unique([clienteId, fecha, nroCierre])
  @@index([clienteId, fecha])
  @@index([clienteId, sucursal, fecha])
}

enum AuditFuente {
  CAJERO
  MOZO
}

enum AuditTipo {
  EMISION
  DESCUENTO
  ELIMINACION
  ESPECIFICACION
  OTRO
}

model sales_closure_audit_events {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  closureId       String         @db.Uuid
  fuente          AuditFuente
  tipo            AuditTipo
  mesa            String?        @db.VarChar(20)
  mozo            String?        @db.VarChar(20)
  comprobante     String?        @db.VarChar(50)
  importeMesa     Decimal?       @db.Decimal(14, 2)
  horaApertura    String?        @db.VarChar(8)
  hora            String?        @db.VarChar(8)
  detalle         String         @db.Text
  monto           Decimal?       @db.Decimal(14, 2)
  porcentaje      Decimal?       @db.Decimal(5, 2)
  productoCodigo  String?        @db.VarChar(20)
  productoNombre  String?        @db.VarChar(255)
  closure         sales_closures @relation(fields: [closureId], references: [id], onDelete: Cascade)

  @@index([closureId])
  @@index([closureId, tipo])
  @@index([closureId, mozo])
  @@index([tipo])
}

model sales_closure_payments {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  closureId   String          @db.Uuid
  formaCobro  String          @db.VarChar(100)
  sigla       String?         @db.VarChar(10)
  total       Decimal         @db.Decimal(14, 2)
  cantidad    Int             @default(0)
  closure     sales_closures  @relation(fields: [closureId], references: [id], onDelete: Cascade)

  @@index([closureId])
  @@index([formaCobro])
}

model sales_closure_items {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  closureId       String                @db.Uuid
  productMasterId String?               @db.Uuid
  rubroCodigo     String?               @db.VarChar(10)
  rubroNombre     String?               @db.VarChar(100)
  codigo          String                @db.VarChar(20)
  nombre          String                @db.VarChar(255)
  unidades        Decimal               @db.Decimal(14, 3)
  importe         Decimal               @db.Decimal(14, 2)
  closure         sales_closures        @relation(fields: [closureId], references: [id], onDelete: Cascade)
  productMaster   sales_product_master? @relation(fields: [productMasterId], references: [id], onDelete: SetNull)

  @@index([closureId])
  @@index([productMasterId])
  @@index([codigo])
  @@index([rubroCodigo])
}

model sales_closure_waiters {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  closureId     String          @db.Uuid
  codigo        String          @db.VarChar(20)
  nombre        String          @db.VarChar(150)
  importe       Decimal         @db.Decimal(14, 2)
  cantVentas    Int             @default(0)
  cantCubiertos Int             @default(0)
  closure       sales_closures  @relation(fields: [closureId], references: [id], onDelete: Cascade)

  @@index([closureId])
  @@index([codigo])
}

model sales_closure_movements {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  closureId       String          @db.Uuid
  tipo            MovimientoTipo
  conceptoCodigo  String          @db.VarChar(50)
  detalle         String          @db.VarChar(255)
  total           Decimal         @db.Decimal(14, 2)
  closure         sales_closures  @relation(fields: [closureId], references: [id], onDelete: Cascade)

  @@index([closureId])
}

model sales_product_master {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId       String                  @db.Uuid
  codigoMaxirest  String                  @db.VarChar(20)
  nombre          String                  @db.VarChar(255)
  rubroCodigo     String?                 @db.VarChar(10)
  rubroNombre     String?                 @db.VarChar(100)
  activo          Boolean                 @default(true)
  lastSeenAt      DateTime?               @db.Timestamptz(3)
  createdAt       DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(3)

  clientes        clientes                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  closureItems    sales_closure_items[]
  recipes         sales_recipes[]

  @@unique([clienteId, codigoMaxirest])
  @@index([clienteId])
  @@index([clienteId, rubroCodigo])
}

model sales_recipes {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productMasterId String                  @db.Uuid
  version         Int                     @default(1)
  activa          Boolean                 @default(true)
  notas           String?                 @db.Text
  createdAt       DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(3)

  productMaster   sales_product_master    @relation(fields: [productMasterId], references: [id], onDelete: Cascade)
  ingredients     sales_recipe_items[]

  @@unique([productMasterId, version])
  @@index([productMasterId, activa])
}

model sales_recipe_items {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipeId          String          @db.Uuid
  insumoId          String?         @db.Uuid
  itemDescripcion   String          @db.VarChar(255)
  itemCompraId      String?         @db.Uuid
  cantidad          Decimal         @db.Decimal(14, 4)
  unidad            String          @db.VarChar(10)
  mermaPct          Decimal         @default(0) @db.Decimal(5, 2)
  notas             String?         @db.Text
  recipe            sales_recipes   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  insumo            insumos?        @relation(fields: [insumoId], references: [id], onDelete: SetNull)

  @@index([recipeId])
  @@index([insumoId])
}

model insumos {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId  String   @db.Uuid
  nombre     String   @db.VarChar(255)
  unidadBase String   @db.VarChar(10)
  categoria  String?  @db.VarChar(100)
  activo     Boolean  @default(true)
  notas      String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  clientes    clientes             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  alias       insumo_alias[]
  recipeItems sales_recipe_items[]

  @@unique([clienteId, nombre])
  @@index([clienteId])
  @@index([clienteId, activo])
}

model insumo_alias {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  insumoId     String   @db.Uuid
  patron       String   @db.VarChar(255)
  factorBase   Decimal  @default(1) @db.Decimal(14, 4)
  unidadOrigen String?  @db.VarChar(20)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  insumo insumos @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  @@unique([insumoId, patron])
  @@index([insumoId])
}

model sales_report_subscriptions {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId   String                @db.Uuid
  nombre      String                @db.VarChar(120)
  frecuencia  FrecuenciaInforme
  diaSemana   Int?
  diaMes      Int?
  hora        String                @default("07:00") @db.VarChar(5)
  tz          String                @default("America/Argentina/Buenos_Aires") @db.VarChar(64)
  sucursal    String?               @db.VarChar(100)
  topN        Int                   @default(10)
  activo      Boolean               @default(true)
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime              @updatedAt @db.Timestamptz(3)

  clientes    clientes              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  recipients  sales_report_subscription_recipients[]
  runs        sales_report_runs[]

  @@index([clienteId])
  @@index([activo, frecuencia])
}

model sales_report_subscription_recipients {
  id              String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId  String                     @db.Uuid
  email           String                     @db.VarChar(255)
  nombre          String?                    @db.VarChar(255)
  usuarioId       String?                    @db.Uuid
  createdAt       DateTime                   @default(now()) @db.Timestamptz(3)

  subscription    sales_report_subscriptions @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, email])
  @@index([subscriptionId])
}

model sales_report_runs {
  id                  String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId      String                     @db.Uuid
  fechaInformeDesde   DateTime                   @db.Date
  fechaInformeHasta   DateTime                   @db.Date
  ejecutadoEn         DateTime                   @default(now()) @db.Timestamptz(3)
  status              StatusInformeRun
  destinatariosCount  Int                        @default(0)
  resendMessageIds    Json                       @default("[]")
  error               String?                    @db.Text

  subscription        sales_report_subscriptions @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, fechaInformeDesde])
  @@index([subscriptionId, ejecutadoEn(sort: Desc)])
}

enum FrecuenciaInforme {
  DIARIA
  SEMANAL
  MENSUAL
}

enum StatusInformeRun {
  OK
  FAIL
  SKIP
}
